{
  "schema": "https://json.schemastore.org/tsconfig",
  "extends": "@vesta-cx/config/typescript/tsup",
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/",
    "outDir": "dist/",
    "rootDir": "src/",
    "types": ["node"]
  }
}
