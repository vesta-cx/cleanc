{
  "schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../packages/config/src/typescript/tsconfig.tsup.json",
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/",
    "outDir": "dist/",
    "rootDir": "src/",
    "types": ["node"]
  }
}
