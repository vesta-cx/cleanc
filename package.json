{
  "name": "cleanc",
  "version": "0.1.0",
  "description": "Clean build outputs and cache directories with Prettier-style config discovery and per-command support",
  "license": "MIT",
  "author": "vesta",
  "type": "module",
  "bin": {
    "cleanc": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": "./schema/cleancrc.schema.json"
  },
  "files": [
    "dist/**/*.?(d.)?([cm])[jt]s?(on?([c5]))",
    "schema/cleancrc.schema.json"
  ],
  "scripts": {
    "clean": "cleanc clean",
    "build:clean": "pnpm run clean && pnpm run build",
    "dev:clean": "pnpm run clean && pnpm run dev",
    "install:clean": "pnpm run clean && node -e \"try{require('fs').rmSync(require('path').join(process.cwd(),'node_modules'),{recursive:true,force:true})}catch(_){}\" && pnpm i",
    "build": "tsup",
    "dev": "tsup --watch",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "lint": "prettier --check . --ignore-path ../../.prettierignore && eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.0",
    "rimraf": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "clean",
    "build",
    "cache",
    "monorepo",
    "prettier-style",
    "config"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vesta-cx/cleanc.git"
  },
  "homepage": "https://github.com/vesta-cx/cleanc#readme",
  "bugs": {
    "url": "https://github.com/vesta-cx/cleanc/issues"
  }
}